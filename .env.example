# Amazon Selling Partner API
AMAZON_SELLING_PARTNER_API_KEY=your_api_key_here
AMAZON_SELLING_PARTNER_API_SECRET=your_api_secret_here
AMAZON_REFRESH_TOKEN=your_refresh_token_here
AMAZON_SELLER_ID=your_seller_id_here

# Supabase (optional - for database backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Data sync schedule (cron format)
SYNC_SCHEDULE=0 2 * * *

# Backup settings
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# Logging
LOG_LEVEL=info
